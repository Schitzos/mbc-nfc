{
  "name": "MbcNfc",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{App.tsx,index.js,__tests__/**/*.ts?(x),src/**/*.ts?(x)}\"",
    "format:check": "prettier --check \"{App.tsx,index.js,__tests__/**/*.ts?(x),src/**/*.ts?(x)}\"",
    "prepare": "husky",
    "start": "react-native start",
    "test": "jest --watchman=false",
    "test:ci": "jest --watchman=false --runInBand --coverage --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --watchman=false --runInBand --coverage"
  },
  "jest-junit": {
    "outputDirectory": "test-results/junit",
    "outputName": "jest-junit.xml"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@op-engineering/op-sqlite": "^15.2.12",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "nativewind": "^4.2.3",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-worklets": "^0.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "jest-junit": "^17.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 20.19.4"
  }
}
